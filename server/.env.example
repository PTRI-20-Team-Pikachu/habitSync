# Supabase JS client — HTTP API credentials (used by supabaseClient.ts)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Direct Postgres pool — used by authentication/src/db/database.ts
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-us-east-2.pooler.supabase.com:6543/postgres
